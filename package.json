{
  "name": "@heroku-cli/heroku-slugs",
  "description": "Heroku CLI Plugin to manage and download slugs",
  "version": "2.0.3",
  "author": "Heroku",
  "bugs": {
    "url": "https://github.com/heroku/heroku-slugs/issues"
  },
  "dependencies": {
    "@heroku-cli/color": "2.0.5",
    "@heroku-cli/command": "^11.5.0",
    "@heroku-cli/notifications": "1.2.6",
    "@oclif/core": "^2.16.0",
    "bytes": "^3.1.2",
    "fs-extra": "^11.3.0",
    "smooth-progress": "^1.1.0"
  },
  "devDependencies": {
    "@heroku-cli/schema": "^2.0.0",
    "@oclif/plugin-help": "^5",
    "@types/bytes": "^3.1.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.3",
    "@types/supports-color": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-oclif": "^6.0.144",
    "nock": "^14.0.0",
    "oclif": "^4.23.0",
    "stdout-stderr": "0.1.13",
    "strip-ansi": "^6.0.1",
    "tsheredoc": "^1.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">= 20"
  },
  "files": [
    "/dist",
    "/oclif.manifest.json"
  ],
  "keywords": [
    "heroku-plugin",
    "oclif"
  ],
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "oclif": {
    "commands": "./dist/commands",
    "bin": "heroku",
    "topics": {
      "slugs": {
        "description": "manage and download slugs"
      }
    }
  },
  "repository": "heroku/heroku-slugs",
  "scripts": {
    "build": "rm -rf dist && tsc -b",
    "lint": "eslint .",
    "postpack": "rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "npm run build && oclif manifest && oclif readme",
    "test": "vitest run --coverage",
    "version": "oclif readme && git add README.md"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
